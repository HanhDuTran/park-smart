# Copy this file to ".env" in the project root and fill in your keys.
# See README.md for where to get each one.

# Mapbox GL JS access token (https://account.mapbox.com/access-tokens/)
# Must be prefixed with VITE_ so Vite exposes it to the frontend.
VITE_MAPBOX_TOKEN=

# Google Places API key, used by the backend to fetch parking lots
# (https://console.cloud.google.com/ -> APIs & Services -> Credentials,
# enable "Places API").
GOOGLE_PLACES_API_KEY=

# Anthropic API key for the voice AI assistant (used in later days).
ANTHROPIC_API_KEY=
